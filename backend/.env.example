# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_SETTINGS_MODULE=core.settings

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# CORS Configuration
# Main frontend URL (required)
FRONTEND_URL=https://cybersecurityap.vercel.app

# Additional CORS origins (comma-separated, optional)
# CORS_ADDITIONAL_ORIGINS=https://another-domain.com,https://staging.example.com

# Additional CSRF trusted origins (comma-separated, optional)
# CSRF_ADDITIONAL_ORIGINS=https://another-domain.com,https://staging.example.com

# Email Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ACCESS_TOKEN_LIFETIME=30
JWT_REFRESH_TOKEN_LIFETIME=7

# Security
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://cybersecurityap.vercel.app,http://localhost:5173,http://127.0.0.1:5173